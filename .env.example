# Database Configuration
# For local development (SQLite)
DATABASE_URL=sqlite:///./gov_grants.db

# For Azure PostgreSQL
# DATABASE_URL=postgresql://username:password@servername.postgres.database.azure.com:5432/gov_grants?sslmode=require

# For Azure SQL Server
# DATABASE_URL=mssql+pyodbc://username:password@servername.database.windows.net:1433/gov_grants?driver=ODBC+Driver+17+for+SQL+Server

# API Configuration
API_TITLE=Government Grants API
API_VERSION=1.0.0
API_DESCRIPTION=API for searching and managing government grant opportunities

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Grants.gov API (when we integrate in Week 3)
GRANTS_GOV_API_KEY=your-grants-gov-api-key

# Azure Configuration (will be used in Week 5)
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=grant-documents
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Email/Notification Settings (will be used in Week 7)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
FROM_EMAIL=noreply@govgrants.com

# Application Settings
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100