# ============================================================
# SECRETS — store these in Azure Key Vault, NOT here
# Key Vault name: gov-grants-msu
#
# To add secrets to Key Vault (Azure Portal):
#   Objects → Secrets → + Generate/Import
#
# Secret names to create:
#   DATABASE-URL
#   AZURE-OPENAI-API-KEY
#   SECRET-KEY
#   BRAVE-SEARCH-API-KEY  (when obtained)
#
# For local dev: run `az login`, then set AZURE_KEYVAULT_URL below.
# Fallback: uncomment and fill in the variables below.
# ============================================================

# Key Vault URL
AZURE_KEYVAULT_URL=https://gov-grants-msu.vault.azure.net/

# Local dev fallback (only if Key Vault is not accessible)
# DATABASE_URL=postgresql://user:password@host:5432/gov_grants?sslmode=require
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# SECRET_KEY=run: python -c "import secrets; print(secrets.token_hex(32))"
# BRAVE_SEARCH_API_KEY=your-brave-search-key

# ============================================================
# NON-SECRET CONFIGURATION
# ============================================================

API_TITLE=Government Grants API
API_VERSION=1.0.0
API_DESCRIPTION=API for searching and managing government grant opportunities

AZURE_OPENAI_ENDPOINT=https://gov-grants-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
